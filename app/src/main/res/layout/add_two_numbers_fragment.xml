<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="#323232">

    <EditText
        android:id="@+id/editNumber1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_first_number"
        android:textColorHint="#80FFFFFF"
        android:textColor="#FFFFFF"
        android:inputType="number"
        android:textSize="14sp"
        android:padding="6dp"
        android:importantForAutofill="no"/>

    <EditText
        android:id="@+id/editNumber2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_second_number"
        android:textColorHint="#80FFFFFF"
        android:textColor="#FFFFFF"
        android:inputType="number"
        android:textSize="14sp"
        android:padding="6dp"
        android:importantForAutofill="no"/>


    <TextView
        android:id="@+id/txtResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/result_placeholder"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:padding="6dp" />


    <GridLayout
        android:id="@+id/gridLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:columnCount="3"
        android:alignmentMode="alignMargins"
        android:useDefaultMargins="true">

        <Button
            style="@style/CalcButton"
            android:id="@+id/btnAdd"
            android:text="@string/add"/>
        <Button
            style="@style/CalcButton"
            android:id="@+id/btnSub"
            android:text="@string/subtract"/>
        <Button
            style="@style/CalcButton"
            android:id="@+id/btnMult"
            android:text="@string/multiply"/>
        <Button
            style="@style/CalcButton"
            android:id="@+id/btnDiv"
            android:text="@string/divide"/>
        <Button
            style="@style/CalcButton"
            android:id="@+id/btnPower"
            android:text="@string/power"/>
        <Button
            style="@style/CalcButton"
            android:id="@+id/btnRoot"
            android:text="@string/root"/>
        <Button
            style="@style/CalcButton"
            android:id="@+id/btnMod"
            android:text="@string/mod"/>
        <Button
            style="@style/CalcButton"
            android:id="@+id/btnLog"
            android:text="@string/log"/>
        <Button
            style="@style/CalcButton"
            android:id="@+id/btnClear"
            android:text="@string/clear"/>

    </GridLayout>

    <TextView
        android:id="@+id/txtFirstOnly"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/first_only_label"
        android:textColor="#FFFFFF"
        android:textAlignment="center"
        android:textStyle="bold"
        android:textSize="13sp"
        android:padding="6dp" />

    <GridLayout
        android:id="@+id/gridLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:alignmentMode="alignMargins"
        android:useDefaultMargins="true">

        <Button
            style="@style/CalcButton"
            android:id="@+id/btnSin"
            android:text="@string/sin"/>
        <Button
            style="@style/CalcButton"
            android:id="@+id/btnCos"
            android:text="@string/cos"/>
        <Button
            style="@style/CalcButton"
            android:id="@+id/btnTan"
            android:text="@string/tan"/>

        <Button
            style="@style/CalcButton"
            android:id="@+id/btnFactorial"
            android:text="@string/factorial"/>

        <Button
            style="@style/CalcButton"
            android:id="@+id/btnLn"
            android:text="@string/ln"/>

    </GridLayout>

</LinearLayout>